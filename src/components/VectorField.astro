---
// Static, reusable SVG diagram of a small 2D coordinate field with one or more
// labeled vectors. Renders arrows on a grid so a lesson can *show* vector
// operations (add tip-to-tail, subtract, scale, length triangle, normalize…).
//
// Coordinate convention matches the screen: origin can be placed anywhere,
// +x goes right, +y goes DOWN (same as raylib — lesson 1 hammered this).
// Vectors are given in "grid units"; we scale them to pixels for drawing.
//
// Props:
//   vectors: Array<{
//     x: number; y: number;            // tip relative to `from`
//     fromX?: number; fromY?: number;  // optional tail, defaults to origin
//     color?: string;                  // CSS color, defaults to primary
//     label?: string;                  // drawn at the tip
//     dashed?: boolean;                // dashed arrow (e.g. a result vector)
//     width?: number;                  // stroke width
//   }>
//   size?: number;            // svg pixel size (square), default 320
//   units?: number;            // how many grid units span the half-width
//   origin?: "center" | "topleft";  default "center"
//   showGrid?: boolean;        default true
//   caption?: string;          // small caption under the diagram
//
// Colors use daisyUI theme vars so the diagram follows the active theme.

type Vec = {
  x: number
  y: number
  fromX?: number
  fromY?: number
  color?: string
  label?: string
  dashed?: boolean
  width?: number
}

type Props = {
  vectors: Vec[]
  size?: number
  units?: number
  origin?: 'center' | 'topleft'
  showGrid?: boolean
  caption?: string
}

const { vectors, size = 320, units = 5, origin = 'center', showGrid = true, caption } = Astro.props

const px = size
const cx = origin === 'center' ? px / 2 : 24
const cy = origin === 'center' ? px / 2 : 24
const scale = (px / 2 - 16) / units // leave a margin

function toScreen(gx: number, gy: number) {
  return {
  x: cx + gx * scale,
  y: cy + gy * scale, // +y down, like a screen
}
}

// Grid lines from -units..+units (center) or 0..units (topleft).
const range
  = origin === 'center'
    ? Array.from({ length: units * 2 + 1 }, (_, i) => i - units)
    : Array.from({ length: units + 1 }, (_, i) => i)

const id = `vf-${Math.random().toString(36).slice(2, 9)}`
const arrowId = `${id}-arrow`
const primary = 'var(--color-primary, currentColor)'
---

<figure class="not-prose my-6 flex flex-col items-center">
  <svg
    viewBox={`0 0 ${px} ${px}`}
    width="100%"
    style={`max-width:${px}px; aspect-ratio:1;`}
    class="rounded-box border border-base-content/15 bg-base-200/30"
    role="img"
    aria-label={caption ?? 'Vector diagram'}
  >
    <defs>
      <marker
        id={arrowId}
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="context-stroke"></path>
      </marker>
      <marker
        id={`${arrowId}-muted`}
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="5"
        markerHeight="5"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="context-stroke" opacity="0.6"></path>
      </marker>
    </defs>

    {
      showGrid
      && range.map(g => (
          <g stroke="currentColor" class="text-base-content/10" stroke-width="1">
            <line
              x1={toScreen(g, origin === 'center' ? -units : 0).x}
              y1={0}
              x2={toScreen(g, origin === 'center' ? units : 0).x}
              y2={px}
            />
            <line x1={0} y1={toScreen(0, g).y} x2={px} y2={toScreen(origin === 'center' ? units : 0, g).y} />
          </g>
        ))
    }

    {/* axes */}
    <g stroke="currentColor" class="text-base-content/40" stroke-width="1.5">
      <line x1={cx} y1={0} x2={cx} y2={px}></line>
      <line x1={0} y1={cy} x2={px} y2={cy}></line>
    </g>
    {/* axis labels */}
    <g class="text-base-content/50" font-size="10" font-family="monospace">
      <text x={px - 12} y={cy - 4} text-anchor="end">+x</text>
      <text x={cx + 4} y={px - 6}>+y</text>
    </g>

    {/* origin dot */}
    <circle cx={cx} cy={cy} r="2.5" class="fill-base-content/50"></circle>

    {
      vectors.map((v) => {
        const from = toScreen(v.fromX ?? 0, v.fromY ?? 0)
        const to = toScreen((v.fromX ?? 0) + v.x, (v.fromY ?? 0) + v.y)
        const col = v.color ?? primary
        return (
          <g stroke={col} fill={col}>
            <line
              x1={from.x}
              y1={from.y}
              x2={to.x}
              y2={to.y}
              stroke-width={v.width ?? 2.5}
              stroke-linecap="round"
              stroke-dasharray={v.dashed ? '5 4' : undefined}
              marker-end={v.dashed ? `url(#${arrowId}-muted)` : `url(#${arrowId})`}
            />
            {v.label && (
              <text
                x={(from.x + to.x) / 2}
                y={(from.y + to.y) / 2 - 6}
                font-size="12"
                font-family="monospace"
                text-anchor="middle"
                stroke="none"
                style="paint-order: stroke; stroke: var(--color-base-100, #fff); stroke-width: 3px;"
              >
                {v.label}
              </text>
            )}
          </g>
        )
      })
    }
  </svg>
  {caption && <figcaption class="text-sm text-base-content/60 mt-2 text-center max-w-md">{caption}</figcaption>}
</figure>
