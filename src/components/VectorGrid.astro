---
import CartesianPlane from './CartesianPlane.astro'

type Common = {
  color?: string
  label?: string
  width?: number
}

type Point = {
  x: number
  y: number
} & Common

type Vector = {
  // End point (absolute grid coordinates).
  x: number
  y: number
  // Start point (absolute grid coordinates); defaults to the origin (0, 0).
  fromX?: number
  fromY?: number
  dashed?: boolean
} & Common

type Props = {
  points?: Point[]
  vectors?: Vector[]
  size?: number
  units?: number
  origin?: 'center' | 'topleft'
  showGrid?: boolean
  caption?: string
}

const { points = [], vectors = [], size = 320, units = 5, origin = 'center', showGrid = true, caption } = Astro.props

const px = size

---

<figure
  class="not-prose my-6 flex flex-col items-center"
  is="vector-grid"
  data-size={px}
  data-units={units}
  data-origin={origin}
  data-show-grid={showGrid ? '1' : '0'}
>
  <CartesianPlane size={size} units={units} origin={origin} showGrid={showGrid} caption={caption} />

  {caption && <figcaption class="text-sm text-base-content/60 mt-2 text-center max-w-md">{caption}</figcaption>}

  {/* per-instance props, read by connectedCallback */}
  <script is:inline type="application/json" class="vg-props" set:html={JSON.stringify({ points, vectors })} />
</figure>

<script>
import type { Vec } from '../lib/vec'
import { query, queryAll, selectIn } from '@vyke/dom'
import van from 'vanjs-core'
import { assert } from '../lib/errors'
import { g } from './elements'
import { VectorArrow } from './VectorArrow'
import { Circle } from './VectorCircle'
import { VectorLabel } from './VectorLabel'

type Common = {
  color?: string
  label?: string
  width?: number
}
type Point = { x: number, y: number } & Common
type Vector = {
  x: number
  y: number
  fromX?: number
  fromY?: number
  dashed?: boolean
} & Common

const PRIMARY = 'var(--color-primary, currentColor)'

let instanceSeq = 0
class VectorGrid extends HTMLElement {
  #ready = false

  connectedCallback(): void {
    if (this.#ready) {
      return
    }
    this.#ready = true

    const [vectorContainer, markers, propsEl] = selectIn(this,
      query<SVGGElement>('.vg-vectors'),
      queryAll<SVGMarkerElement>('marker.vg-arrowhead'),
      query<HTMLScriptElement>('script.vg-props'),
    )

    assert(vectorContainer, 'Missing vector container')
    assert(propsEl, 'Missing props')

    const px = Number(this.dataset.size)
    const units = Number(this.dataset.units)
    const origin = (this.dataset.origin ?? 'center') as 'center' | 'topleft'
    const cx = origin === 'center' ? px / 2 : 24
    const cy = origin === 'center' ? px / 2 : 24
    const pxPerUnit = (px / 2 - 16) / units
    const mapVec = (v: Vec): Vec => ({ x: cx + v.x * pxPerUnit, y: cy + v.y * pxPerUnit })

    const markerId = `vg-ah-${instanceSeq++}`
    markers.forEach((m) => {
      m.id = markerId
    })

    let parsedPoints: Point[] = []
    let parsedVectors: Vector[] = []
    try {
      const data = JSON.parse(propsEl.textContent ?? '{}') as { points?: Point[], vectors?: Vector[] }
      parsedPoints = data.points ?? []
      parsedVectors = data.vectors ?? []
    }
    catch {
      parsedPoints = []
      parsedVectors = []
    }

    for (const p of parsedPoints) {
      const mapped = van.derive(() => p)
      const labelPos = van.derive(() => ({ x: mapped.val.x + 11, y: mapped.val.y + 4 }))
      const color = p.color ?? PRIMARY
      van.add(vectorContainer, g({},
        Circle({
          origin: mapped,
          radius: 9,
          color,
          mapVec,
        }),
        VectorLabel({
          pos: labelPos,
          label: p.label,
          color,
          mapVec,
        }),
      ))
    }
    for (const v of parsedVectors) {
      const to = van.derive(() => v)
      const from = van.derive(() => ({
        x: v.fromX ?? 0, y: v.fromY ?? 0,
      }))

      const color = v.color ?? PRIMARY
      van.add(vectorContainer, VectorArrow({
        mapVec,
        to, from,
        color,
        label: v.label,
        markerId,
      }))
    }
  }
}

customElements.define('vector-grid', VectorGrid, { extends: 'figure' })
</script>
