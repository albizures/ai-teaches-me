---
type Props = {
  size?: number
  units?: number
}

const { size = 340, units = 5 } = Astro.props
---

<vector-ops-playground
  data-size={size}
  data-units={units}
>
<div class="vop-root not-prose my-6 p-4 rounded-box border border-base-content/15 bg-base-200/30"></div>
</vector-ops-playground>

<script>
import type { State as VanState } from 'vanjs-core'
import type { Vec } from '../lib/vec'
import type { Op, ViewCtx } from './vector-ops/views'
import van from 'vanjs-core'
import { clamp, vec } from '../lib/vec'
import { a, circle, defs, div, g, input, label, line, marker, p, path, span, svg, text } from './elements'
import {
  Readout,
  ResultAdd,
  ResultDistance,
  ResultNormalize,
  ResultScale,
  ResultSubtract,
} from './vector-ops/views'

const COL = {
  a: 'oklch(0.7 0.18 30)', // warm (A)
  b: 'oklch(0.65 0.16 220)', // cool (B)
  result: 'var(--color-primary, oklch(0.7 0.18 330))',
  muted: 'var(--color-base-content, #888)',
}

const axisColor = 'color-mix(in oklch, currentColor 45%, transparent)'
const gridColor = 'color-mix(in oklch, currentColor 12%, transparent)'

// Module-level monotonic counter for the arrowhead marker id
let vopSeq = 0

// Stage is `px` × `px`; the axis cross sits dead-centred (cx = cy = px/2);
// `STAGE_MARGIN_PX` of px is reserved at each outer edge so arrowheads /
// handle dots don't clip the viewBox at full drag travel.
const STAGE_MARGIN_PX = 18

customElements.define('vector-ops-playground', class extends HTMLElement {
  connectedCallback(): void {
    const root = this.querySelector<HTMLDivElement>('.vop-root')

    if (root!.childElementCount > 0) {
      return
    }

    const px = Number(this.dataset.size)
    const units = Number(this.dataset.units)
    const cx = px / 2
    const cy = px / 2
    const pxPerUnit = (px / 2 - STAGE_MARGIN_PX) / units
    const pt = (v: Vec): Vec => ({ x: cx + v.x * pxPerUnit, y: cy + v.y * pxPerUnit })
    const markerId = `vop-ah-${vopSeq++}`

    const A = van.state<Vec>(vec(2, 1))
    const B = van.state<Vec>(vec(-1, 2))
    const op = van.state<Op>('add')
    const k = van.state<number>(2)

    const ctx: ViewCtx = { A, B, op, k, pt, markerId, COL }

    // --- static grid + axes (built once; never react to state) ----------
    const gridRange = Array.from({ length: units * 2 + 1 }, (_, i) => i - units)
    const sxN = (gN: number) => cx + gN * pxPerUnit
    const syN = (gN: number) => cy + gN * pxPerUnit

    const gridLayer = g({ 'class': 'grid-layer', 'stroke': gridColor, 'stroke-width': 1 }, ...gridRange.flatMap(gN => [
      line({ x1: sxN(gN), y1: 0, x2: sxN(gN), y2: px }),
      line({ x1: 0, y1: syN(gN), x2: px, y2: syN(gN) }),
    ]))
    const axesLayer = g({ 'class': 'axes-layer', 'stroke': axisColor, 'stroke-width': 1.5 },
      line({ x1: cx, y1: 0, x2: cx, y2: px }),
      line({ x1: 0, y1: cy, x2: px, y2: cy }),
    )

    const resultLayer = g({ class: 'result-layer' }, () => {
      const cur = op.val
      if (cur === 'add')
        return ResultAdd(ctx)
      if (cur === 'subtract')
        return ResultSubtract(ctx)
      if (cur === 'scale')
        return ResultScale(ctx)
      if (cur === 'normalize')
        return ResultNormalize(ctx)
      return ResultDistance(ctx)
    })

    const handle = (atom: VanState<Vec>, which: 'A' | 'B', color: string, glyph: string): SVGGElement => g({},
      circle({
        'cx': () => pt(atom.val).x,
        'cy': () => pt(atom.val).y,
        'r': 9,
        'data-handle': which,
        'tabindex': 0,
        'style': `fill: ${color}; stroke: var(--color-base-100, #fff); stroke-width: 2px; cursor: grab`,
      }),
      text({
        'x': () => pt(atom.val).x + 11,
        'y': () => pt(atom.val).y + 4,
        'font-size': 12,
        'font-family': 'monospace',
        'style': `fill: ${color}; pointer-events: none`,
      }, glyph),
    )

    const handlesLayer = g({ class: 'handles-layer', style: 'cursor: grab' }, handle(A, 'A', COL.a, 'A'), handle(B, 'B', COL.b, 'B'))

    // --- the <svg> stage -----------------------------------------------
    const svgEl = svg(
      {
        viewBox: `0 0 ${px} ${px}`,
        width: px,
        height: px,
        class: 'rounded-box border border-base-content/15 bg-base-100 touch-none select-none',
      },
      defs({}, marker(
        {
          id: markerId,
          viewBox: '0 0 10 10',
          refX: 8,
          refY: 5,
          markerWidth: 6,
          markerHeight: 6,
          orient: 'auto-start-reverse',
        },
        path({ d: 'M0,0 L10,5 L0,10 z', fill: 'context-stroke' }),
      )),
      gridLayer,
      axesLayer,
      resultLayer, // drawn first so A/B handles sit on top
      handlesLayer,
    )

    const tabs: Array<[Op, string]> = [
      ['add', 'Add'],
      ['subtract', 'Subtract'],
      ['scale', 'Scale'],
      ['normalize', 'Normalize'],
      ['distance', 'Distance'],
    ]
    const tablist = div({
      role: 'tablist',
      class: 'tabs tabs-boxed tabs-sm flex-wrap mb-3',
      onclick: (e: MouseEvent) => {
        const t = (e.target as HTMLElement).closest<HTMLElement>('[role="tab"]')
        if (!t) {
          return
        }
        op.val = t.dataset.op as Op
      },
    },
    ...tabs.map(([o, glyph]) => a({
      'role': 'tab',
      'data-op': o,
      'class': () => `tab${op.val === o ? ' tab-active' : ''}`,
    },
    glyph,
    )),
    )

    const scaleOnly = div(
      { class: () => `scale-only mb-3${op.val === 'scale' ? '' : ' hidden'}` },
      label(
        { class: 'text-sm flex items-center justify-between' },
        span({}, 'scale factor ', span({ class: 'badge badge-ghost badge-sm font-mono' }, 'k')),
        span({ class: 'font-mono' }, () => k.val.toFixed(1)),
      ),
      input({
        type: 'range',
        min: -3,
        max: 3,
        step: 0.1,
        value: 2,
        class: 'range range-sm range-primary',
        oninput: (e: Event) => {
          k.val = Number((e.target as HTMLInputElement).value)
        },
      }),
      p({ class: 'text-xs text-base-content/50 mt-1' }, 'k > 1 stretches · 0<k<1 shrinks · k < 0 flips direction.'),
    )

    van.add(root!, div(
      { class: 'flex flex-col lg:flex-row gap-4 items-start' },
      div(
        { class: 'flex-shrink-0 mx-auto' },
        svgEl,
        p({ class: 'text-xs text-base-content/50 mt-1 text-center' }, 'Drag the colored dots. Switch the operation below.'),
      ),
      div(
        { class: 'flex-1 min-w-0 w-full' },
        tablist,
        scaleOnly,
        Readout(ctx),
      ),
    ))

    let dragging: 'A' | 'B' | null = null

    const toData = (evt: PointerEvent): Vec => {
      const rect = svgEl.getBoundingClientRect()
      const sxp = ((evt.clientX - rect.left) / rect.width) * px
      const syp = ((evt.clientY - rect.top) / rect.height) * px
      const gx = (sxp - cx) / pxPerUnit
      const gy = (syp - cy) / pxPerUnit
      return vec(clamp(gx, -units, units), clamp(gy, -units, units))
    }

    svgEl.addEventListener('pointerdown', (e) => {
      const h = (e.target as Element).getAttribute?.('data-handle')
      if (h === 'A' || h === 'B') {
        dragging = h
        svgEl.setPointerCapture(e.pointerId)
      }
    })
    svgEl.addEventListener('pointermove', (e) => {
      if (!dragging) {
        return
      }
      const d = toData(e)
      // Always assign a fresh Vec (fresh-Vec invariant). Drag SAS touches
      // exactly one atom per event — see ADR-0001.
      if (dragging === 'A') {
        A.val = d
      }
      else {
        B.val = d
      }
    })
    svgEl.addEventListener('pointerup', (e) => {
      dragging = null
      svgEl.releasePointerCapture?.(e.pointerId)
    })
    svgEl.addEventListener('pointercancel', () => {
      dragging = null
    })
  }
})
</script>
