---
// Interactive 2D vector playground. The learner drags two vector tips (A and B
// from the origin) and switches between operations to *see* the result drawn
// live, with numeric read-outs for length, distance, etc.
//
// Operations:
//   add      -> A + B   (tip-to-tail)
//   subtract -> B - A   (the vector from A's tip to B's tip)
//   scale    -> A * k   (k chosen with a slider, can be negative)
//   normalize -> A as a unit vector (length 1, same direction)
//   distance -> straight line from A's tip to B's tip
//
// Architecture (ADR-0001):
//   - Static stage chrome (grid, axes, arrowhead <defs>) is SSR'd here in the
//     `.astro` template. It never changes after mount.
//   - The state-driven layers (result arrows, draggable handles, numeric
//     read-out) are owned by a reactive `van`-tree mounted inside this shell.
//   - A stateful `Playground` controller owns the `van.state` atoms
//     (one `Vec` per vector, plus `op` and `k`) and all input handlers
//     (drag, op-tab click, k-slider). Two presentational leaves
//     (`ResultView`, `Readout`) compute their output purely from derived state.
//   - Domain math comes from `src/lib/vec.ts`; SVG primitives and the y-down
//     grid-unit -> screen-pixel mapping come from `src/lib/svg-stage.ts`.
//
// See CONTEXT.md (interactive playground, coordinate convention: y-down) and
// docs/adr/0001-vanjs-for-interactive-widgets.md.
type Props = {
  size?: number
  units?: number
}
const { size = 340, units = 5 } = Astro.props

const px = size
const pxScale = (px / 2 - 18) / units
const cx = px / 2
const cy = px / 2
const id = `vop-${Math.random().toString(36).slice(2, 9)}`

// One grid line per integer unit, plus the centered axes. Static markup only.
const gridRange = Array.from({ length: units * 2 + 1 }, (_, i) => i - units)
const sx = (g: number) => cx + g * pxScale
const sy = (g: number) => cy + g * pxScale
const axisColor = 'color-mix(in oklch, currentColor 45%, transparent)'
const gridColor = 'color-mix(in oklch, currentColor 12%, transparent)'
---

<div
  class="not-prose my-6 p-4 rounded-box border border-base-content/15 bg-base-200/30"
  data-vop={id}
  data-units={units}
  data-scale={pxScale}
  data-px={px}
>
  <div class="flex flex-col lg:flex-row gap-4 items-start">
    {/* SVG stage */}
    <div class="flex-shrink-0 mx-auto">
      <svg
        viewBox={`0 0 ${px} ${px}`}
        width={px}
        height={px}
        class="rounded-box border border-base-content/15 bg-base-100 touch-none select-none"
        id={`${id}-svg`}
      >
        <defs>
          <marker
            id={`${id}-ah`}
            viewBox="0 0 10 10"
            refX="8"
            refY="5"
            markerWidth="6"
            markerHeight="6"
            orient="auto-start-reverse"
          >
            <path d="M0,0 L10,5 L0,10 z" fill="context-stroke"></path>
          </marker>
        </defs>
        {/* grid — static, SSR'd (never changes after mount) */}
        <g class="grid-layer" stroke={gridColor} stroke-width="1">
          {gridRange.map(g => <line x1={sx(g)} y1="0" x2={sx(g)} y2={px} />)}
          {gridRange.map(g => <line x1="0" y1={sy(g)} x2={px} y2={sy(g)} />)}
        </g>
        {/* axes — static, SSR'd */}
        <g class="axes-layer" stroke={axisColor} stroke-width="1.5">
          <line x1={cx} y1="0" x2={cx} y2={px}></line>
          <line x1="0" y1={cy} x2={px} y2={cy}></line>
        </g>
        {/* result vector (drawn first so A/B sit on top) — van-owned, mounted into this <g> */}
        <g class="result-layer"></g>
        {/* A and B handles — van-owned */}
        <g class="handles-layer" style="cursor: grab"></g>
      </svg>
      <p class="text-xs text-base-content/50 mt-1 text-center">Drag the colored dots. Switch the operation below.</p>
    </div>

    {/* controls + read-out */}
    <div class="flex-1 min-w-0 w-full">
      <div role="tablist" class="tabs tabs-boxed tabs-sm flex-wrap mb-3" id={`${id}-ops`}>
        <a role="tab" class="tab" data-op="add">Add</a>
        <a role="tab" class="tab" data-op="subtract">Subtract</a>
        <a role="tab" class="tab" data-op="scale">Scale</a>
        <a role="tab" class="tab" data-op="normalize">Normalize</a>
        <a role="tab" class="tab" data-op="distance">Distance</a>
      </div>

      {/* scale slider — only relevant for the Scale op */}
      <div class="scale-only hidden mb-3">
        <label class="text-sm flex items-center justify-between">
          <span>scale factor <span class="badge badge-ghost badge-sm font-mono">k</span></span>
          <span class="font-mono" id={`${id}-kval`}>2.0</span>
        </label>
        <input type="range" min="-3" max="3" step="0.1" value="2" class="range range-sm range-primary" id={`${id}-k`} />
        <p class="text-xs text-base-content/50 mt-1">
          k &gt; 1 stretches · 0&lt;k&lt;1 shrinks · k &lt; 0 flips direction.
        </p>
      </div>

      {/* numeric read-out — van-owned, mounted into this <div> */}
      <div
        class="font-mono text-sm bg-base-100 rounded-box p-3 border border-base-content/10 space-y-1"
        id={`${id}-readout`}
      >
      </div>
    </div>
  </div>
</div>

<script>
import type { State as VanState } from 'vanjs-core'
import type { Stage } from '../lib/svg-stage'
import type { Vec } from '../lib/vec'
import van from 'vanjs-core'
import { clear, makeStage, mk } from '../lib/svg-stage'
import { add, clamp, distance, fmt, length, normalize, scale, sub, vec } from '../lib/vec'

type Op = 'add' | 'subtract' | 'scale' | 'normalize' | 'distance'

const COL = {
  a: 'oklch(0.7 0.18 30)', // warm (A)
  b: 'oklch(0.65 0.16 220)', // cool (B)
  result: 'var(--color-primary, oklch(0.7 0.18 330))',
  muted: 'var(--color-base-content, #888)',
}

// --- presentational leaf: the result arrows -------------------------------
// Reads state only; never writes. Redraws (imperatively, into a cleared
// `<g>`) whenever a state it reads changes. Variable structure per op is
// exactly why we wrap in a van.derive rather than bind attributes one-by-one.
function ResultView(stage: Stage, resultLayer: SVGGElement, get: VecState) {
  const O = vec(0, 0)
  van.derive(() => {
    const A = get.A.val
    const B = get.B.val
    const op = get.op.val
    const k = get.k.val
    clear(resultLayer)

    if (op === 'add') {
      const sum = add(A, B)
      stage.arrow(resultLayer, O, A, COL.a, { label: 'A' })
      stage.arrow(resultLayer, A, sum, COL.b, { label: 'B' })
      stage.arrow(resultLayer, O, sum, COL.result, { width: 4, dashed: true, label: 'A+B' })
    }
    else if (op === 'subtract') {
      stage.arrow(resultLayer, O, A, COL.a, { label: 'A' })
      stage.arrow(resultLayer, O, B, COL.b, { label: 'B' })
      stage.arrow(resultLayer, A, B, COL.result, { width: 4, dashed: true, label: 'B\u2212A' })
    }
    else if (op === 'scale') {
      const scaled = scale(A, k)
      stage.arrow(resultLayer, O, A, COL.a, { dashed: true, label: 'A' })
      stage.arrow(resultLayer, O, scaled, COL.result, { width: 4, label: `A\u00D7${fmt(k)}` })
    }
    else if (op === 'normalize') {
      const l = length(A)
      const n = normalize(A)
      stage.arrow(resultLayer, O, A, COL.a, { dashed: true, label: `A |A|=${fmt(l)}` })
      stage.arrow(resultLayer, O, n, COL.result, { width: 4, label: '\u00C2 (unit)' })
      // unit circle marker
      // unit circle: radius 1 grid unit. circlePlain converts to pixels via the stage mapping.
      stage.circlePlain(resultLayer, 1, COL.result)
    }
    else if (op === 'distance') {
      stage.arrow(resultLayer, O, A, COL.a, { label: 'A' })
      stage.arrow(resultLayer, O, B, COL.b, { label: 'B' })
      // underscore the line tip-to-tip with a dashed marker-less arrow.
      const a = stage.pt(A)
      const b = stage.pt(B)
      const line = mk('line', {
        'x1': String(a.x),
        'y1': String(a.y),
        'x2': String(b.x),
        'y2': String(b.y),
        'stroke-dasharray': '5 4',
        'stroke-width': '4',
      }) as SVGLineElement
        ;(line.style as unknown as Record<string, string>).stroke = COL.result
      line.setAttribute('marker-end', `url(#${get.markerId})`)
      resultLayer.appendChild(line)
    }
  })
}

// --- presentational leaf: the numeric read-out ----------------------------
function Readout(readout: HTMLElement, get: VecState) {
  van.derive(() => {
    const A = get.A.val
    const B = get.B.val
    const op = get.op.val
    const k = get.k.val
    let lines: string[] = []
    if (op === 'add') {
      const sum = add(A, B)
      lines = [
        `A   = (${fmt(A.x)}, ${fmt(A.y)})   |A|=${fmt(length(A))}`,
        `B   = (${fmt(B.x)}, ${fmt(B.y)})   |B|=${fmt(length(B))}`,
        `A+B = (${fmt(sum.x)}, ${fmt(sum.y)})   |A+B|=${fmt(length(sum))}`,
      ]
    }
    else if (op === 'subtract') {
      const diff = sub(B, A)
      lines = [
        `A   = (${fmt(A.x)}, ${fmt(A.y)})`,
        `B   = (${fmt(B.x)}, ${fmt(B.y)})`,
        `B\u2212A = (${fmt(diff.x)}, ${fmt(diff.y)})   |B\u2212A|=${fmt(length(diff))}`,
        `B\u2212A points from A's tip to B's tip`,
      ]
    }
    else if (op === 'scale') {
      const scaled = scale(A, k)
      lines = [
        `A      = (${fmt(A.x)}, ${fmt(A.y)})`,
        `k      = ${fmt(k)}`,
        `A\u00D7k    = (${fmt(scaled.x)}, ${fmt(scaled.y)})`,
        `|A\u00D7k|  = ${fmt(length(scaled))} (= |A|\u00B7|k| = ${fmt(length(A) * Math.abs(k))})`,
      ]
    }
    else if (op === 'normalize') {
      const l = length(A)
      const n = normalize(A)
      lines = [
        `A   = (${fmt(A.x)}, ${fmt(A.y)})   |A|=${fmt(l)}`,
        `\u00C2 = A / |A| = (${fmt(n.x)}, ${fmt(n.y)})`,
        `|\u00C2| = ${fmt(length(n))}  (always 1)`,
        `Dashed circle = radius 1 (the unit circle)`,
      ]
    }
    else if (op === 'distance') {
      const d = distance(A, B)
      lines = [
        `A = (${fmt(A.x)}, ${fmt(A.y)})`,
        `B = (${fmt(B.x)}, ${fmt(B.y)})`,
        `distance = |B \u2212 A| = ${fmt(d)}`,
        `(= sqrt(dx\u00B2 + dy\u00B2), Pythagoras)`,
      ]
    }
    readout.innerHTML = lines.map(l => `<div>${l}</div>`).join('')
  })
}

// --- bundle of (possibly) shared state accessors -------------------------
interface VecState {
  A: VanState<Vec>
  B: VanState<Vec>
  op: VanState<Op>
  k: VanState<number>
  markerId: string
}

// --- controller: owns state + input, mounts both leaves ------------------
function initVOP(root: HTMLElement) {
  if (root.dataset.ready === '1') {
    return
  }
  root.dataset.ready = '1'

  const id = root.dataset.vop!
  const units = Number(root.dataset.units)
  const pxPerUnit = Number(root.dataset.scale)
  const px = Number(root.dataset.px)
  const cx = px / 2
  const cy = px / 2
  const markerId = `${id}-ah`

  const stage = makeStage(cx, cy, pxPerUnit, markerId)
  // Optional TODO: cache radius mapping? pxPerUnit is used as "radius-1 unit" circle marker.

  // State: one `van.state<Vec>` per vector (kept whole), plus `op` and `k`.
  const A = van.state<Vec>(vec(2, 1))
  const B = van.state<Vec>(vec(-1, 2))
  const op = van.state<Op>('add')
  const k = van.state<number>(2)

  const get: VecState = { A, B, op, k, markerId }

  const resultLayer = root.querySelector<SVGGElement>('.result-layer')!
  const handlesLayer = root.querySelector<SVGGElement>('.handles-layer')!
  const readout = root.querySelector<HTMLElement>(`#${id}-readout`)!
  const svg = root.querySelector<SVGSVGElement>(`#${id}-svg`)!
  const opsBar = root.querySelector<HTMLElement>(`#${id}-ops`)!
  const scaleOnly = root.querySelector<HTMLElement>('.scale-only')!
  const kSlider = root.querySelector<HTMLInputElement>(`#${id}-k`)!
  const kVal = root.querySelector<HTMLElement>(`#${id}-kval`)!

  // Mount the two presentational leaves.
  ResultView(stage, resultLayer, get)
  Readout(readout, get)

  // Handles are owned by the controller: they're the drag input source, so
  // pulling them into a child would mean passing setters back up — ceremony
  // over clarity. Their *positions* still derive reactively from A/B.
  //
  // Invariant (ADR-0001 Q8): Vec atoms must be assigned a *fresh* Vec on
  // every change.Vanjs dedups notifications by reference inequality, so
  // `A.val.x = ...` (mutate in place) would silently skip this redraw.
  van.derive(() => {
    clear(handlesLayer)
    stage.dot(handlesLayer, A.val, COL.a, 'A', 'A')
    stage.dot(handlesLayer, B.val, COL.b, 'B', 'B')
  })

  // Tab-styling + slider visibility derive purely from `op`.
  van.derive(() => {
    const cur = op.val
    opsBar
      .querySelectorAll<HTMLElement>('[role="tab"]')
      .forEach(t => t.classList.toggle('tab-active', t.dataset.op === cur))
    scaleOnly.classList.toggle('hidden', cur !== 'scale')
  })

  // k-slider label derives purely from `k`.
  van.derive(() => {
    kVal.textContent = k.val.toFixed(1)
  })

  // ---- input handlers (the only writers of state) ----
  opsBar.addEventListener('click', (e) => {
    const t = (e.target as HTMLElement).closest<HTMLElement>('[role="tab"]')
    if (!t) {
      return
    }
    op.val = t.dataset.op as Op
  })
  kSlider.addEventListener('input', () => {
    k.val = Number(kSlider.value)
  })

  // ---- drag handles ----
  let dragging: 'A' | 'B' | null = null

  // grid-unit Vec under the pointer, clamped to the playable range.
  const toData = (evt: PointerEvent): Vec => {
    const rect = svg.getBoundingClientRect()
    const sxp = ((evt.clientX - rect.left) / rect.width) * px
    const syp = ((evt.clientY - rect.top) / rect.height) * px
    const gx = (sxp - cx) / pxPerUnit
    const gy = (syp - cy) / pxPerUnit
    return vec(clamp(gx, -units, units), clamp(gy, -units, units))
  }

  svg.addEventListener('pointerdown', (e) => {
    const h = (e.target as Element).getAttribute?.('data-handle')
    if (h === 'A' || h === 'B') {
      dragging = h
      svg.setPointerCapture(e.pointerId)
    }
  })
  svg.addEventListener('pointermove', (e) => {
    if (!dragging)
      return
    const d = toData(e)
    // Always assign a fresh Vec (see invariant above). Drag SAS touches
    // exactly one atom per event — see ADR-0001.
    if (dragging === 'A') {
      A.val = d
    }
    else {
      B.val = d
    }
  })
  svg.addEventListener('pointerup', (e) => {
    dragging = null
    svg.releasePointerCapture?.(e.pointerId)
  })
  svg.addEventListener('pointercancel', () => {
    dragging = null
  })
}

// Lifecycle (L0 from ADR-0001 / the grilling session): keep today's pattern
// exactly — `initAll` runs on script load and again on `astro:page-load`
// (View Transitions), with `dataset.ready` guarding against a double mount
// of the same element. Listeners attach to elements inside this shell only
// (never `document`/`window`), so the module-level hook is the only
// document-level listener.
function initAll() {
  document.querySelectorAll<HTMLElement>('[data-vop]').forEach(initVOP)
}
initAll()
document.addEventListener('astro:page-load', initAll)
</script>
