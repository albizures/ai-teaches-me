---
// Interactive 2D vector playground. The learner drags two vector tips (A and B
// from the origin) and switches between operations to *see* the result drawn
// live, with numeric read-outs for length, distance, etc.
//
// Operations:
//   add      -> A + B   (tip-to-tail)
//   subtract -> B - A   (the vector from A's tip to B's tip)
//   scale    -> A * k   (k chosen with a slider, can be negative)
//   normalize -> A as a unit vector (length 1, same direction)
//   distance -> straight line from A's tip to B's tip
//
// All deps: plain DOM + SVG. No framework. daisyUI classes for styling so it
// follows the active theme.
type Props = {
  size?: number;
  units?: number;
};
const {
  size = 340,
  units = 5,
} = Astro.props;

const px = size;
const scale = (px / 2 - 18) / units;
const id = `vop-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class="not-prose my-6 p-4 rounded-box border border-base-content/15 bg-base-200/30"
  data-vop={id}
  data-units={units}
  data-scale={scale}
  data-px={px}
>
  <div class="flex flex-col lg:flex-row gap-4 items-start">
    {/* SVG stage */}
    <div class="flex-shrink-0 mx-auto">
      <svg
        viewBox={`0 0 ${px} ${px}`}
        width={px}
        height={px}
        class="rounded-box border border-base-content/15 bg-base-100 touch-none select-none"
        id={`${id}-svg`}
      >
        <defs>
          <marker id={`${id}-ah`} viewBox="0 0 10 10" refX="8" refY="5"
            markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="context-stroke" />
          </marker>
        </defs>
        {/* grid */}
        <g class="grid-layer" stroke="currentColor" stroke-width="1"></g>
        {/* axes */}
        <g class="axes-layer" stroke="currentColor" stroke-width="1.5"></g>
        {/* result vector (drawn first so A/B sit on top) */}
        <g class="result-layer"></g>
        {/* A and B */}
        <g class="handles-layer" style="cursor: grab"></g>
      </svg>
      <p class="text-xs text-base-content/50 mt-1 text-center">
        Drag the colored dots. Switch the operation below.
      </p>
    </div>

    {/* controls + read-out */}
    <div class="flex-1 min-w-0 w-full">
      <div role="tablist" class="tabs tabs-boxed tabs-sm flex-wrap mb-3" id={`${id}-ops`}>
        <a role="tab" class="tab" data-op="add">Add</a>
        <a role="tab" class="tab" data-op="subtract">Subtract</a>
        <a role="tab" class="tab" data-op="scale">Scale</a>
        <a role="tab" class="tab" data-op="normalize">Normalize</a>
        <a role="tab" class="tab" data-op="distance">Distance</a>
      </div>

      {/* scale slider — only relevant for the Scale op */}
      <div class="scale-only hidden mb-3">
        <label class="text-sm flex items-center justify-between">
          <span>scale factor <span class="badge badge-ghost badge-sm font-mono">k</span></span>
          <span class="font-mono" id={`${id}-kval`}>2.0</span>
        </label>
        <input type="range" min="-3" max="3" step="0.1" value="2"
          class="range range-sm range-primary" id={`${id}-k`} />
        <p class="text-xs text-base-content/50 mt-1">
          k &gt; 1 stretches · 0&lt;k&lt;1 shrinks · k &lt; 0 flips direction.
        </p>
      </div>

      {/* numeric read-out */}
      <div class="font-mono text-sm bg-base-100 rounded-box p-3 border border-base-content/10 space-y-1" id={`${id}-readout`}>
      </div>
    </div>
  </div>
</div>

<script>
  function initVOP(root: HTMLElement) {
    if (root.dataset.ready === "1") return;
    root.dataset.ready = "1";

    const id = root.dataset.vop!;
    const units = Number(root.dataset.units);
    const scale = Number(root.dataset.scale);
    const px = Number(root.dataset.px);
    const cx = px / 2;
    const cy = px / 2;

    const COL = {
      a: "oklch(0.7 0.18 30)",   // warm (A)
      b: "oklch(0.65 0.16 220)",  // cool (B)
      result: "var(--color-primary, oklch(0.7 0.18 330))",
      muted: "var(--color-base-content, #888)",
    };

    // State (screen coords: +y is downward)
    let A = { x: 2, y: 1 };
    let B = { x: -1, y: 2 };
    let op = "add";
    let k = 2;

    const gridLayer = root.querySelector<SVGGElement>(".grid-layer")!;
    const axesLayer = root.querySelector<SVGGElement>(".axes-layer")!;
    const resultLayer = root.querySelector<SVGGElement>(".result-layer")!;
    const handlesLayer = root.querySelector<SVGGElement>(".handles-layer")!;
    const readout = root.querySelector<HTMLElement>(`#${id}-readout`)!;
    const opsBar = root.querySelector<HTMLElement>(`#${id}-ops`)!;
    const scaleOnly = root.querySelector<HTMLElement>(".scale-only")!;
    const kSlider = root.querySelector<HTMLInputElement>(`#${id}-k`)!;
    const kVal = root.querySelector<HTMLElement>(`#${id}-kval`)!;

    const s = (gx: number, gy: number) => ({ x: cx + gx * scale, y: cy + gy * scale });

    const NS = "http://www.w3.org/2000/svg";
    function mk<K extends keyof SVGElementTagNameMap>(name: K, attrs: Record<string, string> = {}): SVGElementTagNameMap[K] {
      const el = document.createElementNS(NS, name);
      for (const [k2, v2] of Object.entries(attrs)) el.setAttribute(k2, v2);
      return el;
    };

    // build grid + axes once
    const range = Array.from({ length: units * 2 + 1 }, (_, i) => i - units);
    range.forEach((g) => {
      const p1 = s(g, -units), p2 = s(g, units);
      gridLayer.appendChild(mk("line", { x1: String(p1.x), y1: "0", x2: String(p2.x), y2: String(px) }));
      gridLayer.appendChild(mk("line", { x1: "0", y1: String(s(0, g).y), x2: String(px), y2: String(s(0, g).y) }));
    });
    gridLayer.setAttribute("class", "grid-layer");
    gridLayer.setAttribute("stroke", "currentColor");
    gridLayer.style.color = "color-mix(in oklch, currentColor 12%, transparent)";
    axesLayer.appendChild(mk("line", { x1: String(cx), y1: "0", x2: String(cx), y2: String(px) }));
    axesLayer.appendChild(mk("line", { x1: "0", y1: String(cy), x2: String(px), y2: String(cy) }));
    axesLayer.style.color = "color-mix(in oklch, currentColor 45%, transparent)";

    function arrow(layer: SVGGElement, from: {x:number;y:number}, to: {x:number;y:number}, color: string, w = 3, dashed = false, label?: string) {
      const a = s(from.x, from.y), b = s(to.x, to.y);
      const line = mk("line", {
        x1: String(a.x), y1: String(a.y), x2: String(b.x), y2: String(b.y),
        "stroke": color, "stroke-width": String(w),
        "stroke-linecap": "round",
        "marker-end": `url(#${id}-ah)`,
      });
      if (dashed) line.setAttribute("stroke-dasharray", "5 4");
      line.style.stroke = color;
      // marker fill follows context-stroke; set stroke directly:
      (line as any).style.stroke = color;
      layer.appendChild(line);
      if (label) {
        const t = mk("text", {
          x: String(b.x + 6), y: String(b.y - 4),
          "font-size": "12", "font-family": "monospace",
        });
        t.textContent = label;
        (t as any).style.fill = color;
        layer.appendChild(t);
      }
    }

    function dot(layer: SVGGElement, p: {x:number;y:number}, color: string, label: string) {
      const sp = s(p.x, p.y);
      const c = mk("circle", { cx: String(sp.x), cy: String(sp.y), r: "9" });
      c.style.fill = color;
      c.style.stroke = "var(--color-base-100, #fff)";
      c.style.strokeWidth = "2";
      c.style.cursor = "grab";
      c.dataset.handle = label;
      c.setAttribute("tabindex", "0");
      layer.appendChild(c);
      const t = mk("text", { x: String(sp.x + 11), y: String(sp.y + 4), "font-size": "12", "font-family": "monospace" });
      t.textContent = label;
      (t as any).style.fill = color;
      (t as any).style.pointerEvents = "none";
      layer.appendChild(t);
    }

    function clearLayer(layer: SVGGElement) { while (layer.firstChild) layer.removeChild(layer.firstChild); }

    function length(v: {x:number;y:number}) { return Math.hypot(v.x, v.y); }
    function fmt(n: number) { return (Math.round(n * 100) / 100).toString(); }

    function render() {
      clearLayer(resultLayer);
      clearLayer(handlesLayer);
      const O = { x: 0, y: 0 };
      let lines: string[] = [];

      if (op === "add") {
        const sum = { x: A.x + B.x, y: A.y + B.y };
        arrow(resultLayer, O, A, COL.a, 3, false, "A");
        arrow(resultLayer, A, { x: A.x + B.x, y: A.y + B.y }, COL.b, 3, false, "B");
        arrow(resultLayer, O, sum, COL.result, 4, true, "A+B");
        lines = [
          `A   = (${fmt(A.x)}, ${fmt(A.y)})   |A|=${fmt(length(A))}`,
          `B   = (${fmt(B.x)}, ${fmt(B.y)})   |B|=${fmt(length(B))}`,
          `A+B = (${fmt(sum.x)}, ${fmt(sum.y)})   |A+B|=${fmt(length(sum))}`,
        ];
      } else if (op === "subtract") {
        // B - A is the vector from A's tip to B's tip
        const diff = { x: B.x - A.x, y: B.y - A.y };
        arrow(resultLayer, O, A, COL.a, 3, false, "A");
        arrow(resultLayer, O, B, COL.b, 3, false, "B");
        arrow(resultLayer, A, B, COL.result, 4, true, "B−A");
        lines = [
          `A   = (${fmt(A.x)}, ${fmt(A.y)})`,
          `B   = (${fmt(B.x)}, ${fmt(B.y)})`,
          `B−A = (${fmt(diff.x)}, ${fmt(diff.y)})   |B−A|=${fmt(length(diff))}`,
          `B−A points from A's tip to B's tip`,
        ];
      } else if (op === "scale") {
        const scaled = { x: A.x * k, y: A.y * k };
        arrow(resultLayer, O, A, COL.a, 3, true, "A");
        arrow(resultLayer, O, scaled, COL.result, 4, false, `A×${fmt(k)}`);
        lines = [
          `A      = (${fmt(A.x)}, ${fmt(A.y)})`,
          `k      = ${fmt(k)}`,
          `A×k    = (${fmt(scaled.x)}, ${fmt(scaled.y)})`,
          `|A×k|  = ${fmt(length(scaled))} (= |A|·|k| = ${fmt(length(A) * Math.abs(k))})`,
        ];
      } else if (op === "normalize") {
        const l = length(A);
        const n = l > 0 ? { x: A.x / l, y: A.y / l } : { x: 0, y: 0 };
        arrow(resultLayer, O, A, COL.a, 3, true, `A |A|=${fmt(l)}`);
        arrow(resultLayer, O, n, COL.result, 4, false, "Â (unit)");
        // also mark the unit circle
        const c = mk("circle", { cx: String(cx), cy: String(cy), r: String(scale) });
        c.style.fill = "none";
        c.style.stroke = COL.result;
        c.style.strokeWidth = "1";
        c.style.strokeDasharray = "3 3";
        c.style.opacity = "0.5";
        resultLayer.appendChild(c);
        lines = [
          `A   = (${fmt(A.x)}, ${fmt(A.y)})   |A|=${fmt(l)}`,
          `Â = A / |A| = (${fmt(n.x)}, ${fmt(n.y)})`,
          `|Â| = ${fmt(length(n))}  (always 1)`,
          `Dashed circle = radius 1 (the unit circle)`,
        ];
      } else if (op === "distance") {
        arrow(resultLayer, O, A, COL.a, 3, false, "A");
        arrow(resultLayer, O, B, COL.b, 3, false, "B");
        const diff = { x: B.x - A.x, y: B.y - A.y };
        // draw line between tips
        const a = s(A.x, A.y), b = s(B.x, B.y);
        const line = mk("line", { x1: String(a.x), y1: String(a.y), x2: String(b.x), y2: String(b.y), "stroke-dasharray": "5 4", "stroke-width": "3" });
        line.style.stroke = COL.result;
        line.setAttribute("marker-end", `url(#${id}-ah)`);
        resultLayer.appendChild(line);
        lines = [
          `A = (${fmt(A.x)}, ${fmt(A.y)})`,
          `B = (${fmt(B.x)}, ${fmt(B.y)})`,
          `distance = |B − A| = ${fmt(length(diff))}`,
          `(= sqrt(dx² + dy²), Pythagoras)`,
        ];
      }

      readout.innerHTML = lines.map((l) => `<div>${l}</div>`).join("");
      dot(handlesLayer, A, COL.a, "A");
      dot(handlesLayer, B, COL.b, "B");

      // tabs active state
      opsBar.querySelectorAll<HTMLElement>('[role="tab"]').forEach((t) => {
        t.classList.toggle("tab-active", t.dataset.op === op);
      });
      scaleOnly.classList.toggle("hidden", op !== "scale");
    }

    // operation selection
    opsBar.addEventListener("click", (e) => {
      const t = (e.target as HTMLElement).closest('[role="tab"]') as HTMLElement | null;
      if (!t) return;
      op = t.dataset.op!;
      render();
    });
    kSlider.addEventListener("input", () => {
      k = Number(kSlider.value);
      kVal.textContent = k.toFixed(1);
      render();
    });

    // dragging handles
    const svg = root.querySelector<SVGSVGElement>(`#${id}-svg`)!;
    let dragging: "A" | "B" | null = null;

    function toData(evt: PointerEvent) {
      const rect = svg.getBoundingClientRect();
      const sx = ((evt.clientX - rect.left) / rect.width) * px;
      const sy = ((evt.clientY - rect.top) / rect.height) * px;
      const gx = (sx - cx) / scale;
      const gy = (sy - cy) / scale;
      // clamp to grid
      const cl = (v: number) => Math.max(-units, Math.min(units, v));
      return { x: cl(gx), y: cl(gy) };
    }

    svg.addEventListener("pointerdown", (e) => {
      const h = (e.target as Element).getAttribute?.("data-handle");
      if (h === "A" || h === "B") {
        dragging = h;
        svg.setPointerCapture(e.pointerId);
        (e.target as Element).setAttribute("style", ((e.target as Element).getAttribute("style") || "") + ";cursor:grabbing;");
      }
    });
    svg.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const d = toData(e);
      if (dragging === "A") A = d;
      else B = d;
      render();
    });
    svg.addEventListener("pointerup", (e) => { dragging = null; svg.releasePointerCapture?.(e.pointerId); });
    svg.addEventListener("pointercancel", () => { dragging = null; });

    render();
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>("[data-vop]").forEach(initVOP);
  }
  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>