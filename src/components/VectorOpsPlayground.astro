---
import CartesianPlane from './CartesianPlane.astro'

type Props = {
  size?: number
  units?: number
}
const { size = 340, units = 5 } = Astro.props


---

<vector-ops-playground
  data-size={size}
  data-units={units}
>
  <div class="grid grid-cols-2 gap-4 not-prose my-6 p-4 flex rounded-box border border-base-content/15 bg-base-200/30">
    <div class="vector-grid flex flex-col items-center">
      <CartesianPlane size={size} units={5} />
    </div>
    <div class="tabs tabs-lift tabs-sm">
      <input type="radio" name="vop-result" value="add" class="tab" aria-label="Add" checked="checked" />
      <div class="tab-content bg-base-100 border-base-300 p-4 add-result"></div>

      <input type="radio" name="vop-result" value="subtrack" class="tab" aria-label="Subtrack" />
      <div class="tab-content bg-base-100 border-base-300 p-4 subtrack-result"></div>

      <input type="radio" name="vop-result" value="scale" class="tab" aria-label="Scale" />
      <div class="tab-content bg-base-100 border-base-300 p-4 scale-result"></div>

      <input type="radio" name="vop-result" value="normalize" class="tab" aria-label="Normalize" />
      <div class="tab-content bg-base-100 border-base-300 p-4 normalize-result"></div>

      <input type="radio" name="vop-result" value="distance" class="tab" aria-label="Distance" />
      <div class="tab-content bg-base-100 border-base-300 p-4 distance-result"></div>
    </div>
  </div>
</vector-ops-playground>

<script>
import type { State as VanState } from 'vanjs-core'
import type { Vec } from '../lib/vec'
import type { Op, ViewCtx } from './VectorElements'
import { on, query, queryAll, selectIn } from '@vyke/dom'
import van from 'vanjs-core'
import { assert } from '../lib/errors'
import { clamp, vec } from '../lib/vec'
import { defs, div, g, input, label, marker, p, path, span } from './elements'
import { Circle } from './VectorCircle'
import {
  Readout,
  ResultAdd,
  ResultDistance,
  ResultNormalize,
  ResultScale,
  ResultSubtract,
} from './VectorElements'
import { VectorLabel } from './VectorLabel'

const COL = {
  a: 'oklch(0.7 0.18 30 / 0.5)', // warm (A)
  b: 'oklch(0.65 0.16 220 / 0.5)', // cool (B)
  result: 'var(--color-primary, oklch(0.7 0.18 330))',
  muted: 'var(--color-base-content, #888)',
}

// Module-level monotonic counter for the arrowhead marker id
let vopSeq = 0

// Stage is `px` × `px`; the axis cross sits dead-centred (cx = cy = px/2);
// `STAGE_MARGIN_PX` of px is reserved at each outer edge so arrowheads /
// handle dots don't clip the viewBox at full drag travel.
const STAGE_MARGIN_PX = 18

customElements.define('vector-ops-playground', class extends HTMLElement {
  #ready = false
  connectedCallback(): void {
    if (this.#ready) {
      return
    }
    this.#ready = true

    const [addDiv, subtrackDiv, scaleDiv, normalizeDiv, distanceDiv, cartesianPlane, tabs] = selectIn(this,
      query<HTMLDivElement>('.add-result'),
      query<HTMLDivElement>('.subtrack-result'),
      query<HTMLDivElement>('.scale-result'),
      query<HTMLDivElement>('.normalize-result'),
      query<HTMLDivElement>('.distance-result'),
      query<SVGElement>('.cartesian-plane'),
      queryAll<HTMLInputElement>('[name=vop-result]'),
    )

    assert(cartesianPlane, 'Missing cartesian plane')

    const px = Number(this.dataset.size)
    const units = Number(this.dataset.units)
    const cx = px / 2
    const cy = px / 2
    const origin = van.state<Vec>({ x: 0, y: 0 })
    const pxPerUnit = (px / 2 - STAGE_MARGIN_PX) / units
    const mapVec = (v: Vec): Vec => ({ x: cx + v.x * pxPerUnit, y: cy + v.y * pxPerUnit })
    const markerId = `vop-ah-${vopSeq++}`

    const A = van.state<Vec>(vec(2, 1))
    const B = van.state<Vec>(vec(-1, 2))
    const op = van.state<Op>('add')
    const k = van.state<number>(0.5)

    for (const tab of tabs) {
      on(tab, 'click', (event) => {
        const target = event.target
        assert(target instanceof HTMLInputElement, 'invalid event')

        op.val = target.value as Op
      })
    }

    const ctx: ViewCtx = { A, B, op, k, markerId, COL, unit: units, origin, mapVec }

    const scaleOnly = div(
      { class: () => `scale-only mb-3${op.val === 'scale' ? '' : ' hidden'}` },
      label(
        { class: 'text-sm flex items-center justify-between' },
        span({}, 'scale factor ', span({ class: 'badge badge-ghost badge-sm font-mono' }, 'k')),
        span({ class: 'font-mono' }, () => k.val.toFixed(1)),
      ),
      input({
        type: 'range',
        min: -3,
        max: 3,
        step: 0.1,
        value: k,
        class: 'range range-sm range-primary',
        oninput(event: Event) {
          const target = event.target
          assert(target instanceof HTMLInputElement, 'Invalid range')
          k.val = Number(target.value)
        },
      }),
      p({ class: 'text-xs text-base-content/50 mt-1' }, 'k > 1 stretches · 0<k<1 shrinks · k < 0 flips direction.'),
    )

    const resultLayer = g({ class: 'result-layer' }, () => {
      const cur = op.val
      if (cur === 'add')
        return ResultAdd(ctx)
      if (cur === 'subtract')
        return ResultSubtract(ctx)
      if (cur === 'scale')
        return ResultScale(ctx)
      if (cur === 'normalize')
        return ResultNormalize(ctx)
      return ResultDistance(ctx)
    })

    van.add(addDiv!, Readout('add', ctx))
    van.add(subtrackDiv!, Readout('subtract', ctx))
    van.add(scaleDiv!, scaleOnly, Readout('scale', ctx))
    van.add(normalizeDiv!, Readout('normalize', ctx))
    van.add(distanceDiv!, Readout('distance', ctx))

    function Handle(atom: VanState<Vec>, which: 'A' | 'B', color: string, label: string) {
      const labelPos = van.derive(() => ({ x: atom.val.x + 0.1, y: atom.val.y + 0.1 }))

      return g({},
        Circle({
          origin: atom,
          radius: 9,
          color,
          handle: which,
          tabindex: 0,
          mapVec,
        }),
        VectorLabel({
          pos: labelPos,
          label,
          color,
          mapVec,
        }),
      )
    }

    const handlesLayer = g({ class: 'handles-layer', style: 'cursor: grab' },
      Handle(A, 'A', COL.a, 'A'),
      Handle(B, 'B', COL.b, 'B'),
    )

    van.add(cartesianPlane!,
      defs({}, marker(
        {
          id: markerId,
          viewBox: '0 0 10 10',
          refX: 8,
          refY: 5,
          markerWidth: 6,
          markerHeight: 6,
          orient: 'auto-start-reverse',
        },
        path({ d: 'M0,0 L10,5 L0,10 z', fill: 'context-stroke' }),
      )),
      resultLayer,
      handlesLayer,
    )

    let dragging: 'A' | 'B' | null = null

    const toData = (evt: PointerEvent): Vec => {
      const rect = cartesianPlane.getBoundingClientRect()
      const sxp = ((evt.clientX - rect.left) / rect.width) * px
      const syp = ((evt.clientY - rect.top) / rect.height) * px
      const gx = (sxp - cx) / pxPerUnit
      const gy = (syp - cy) / pxPerUnit
      return vec(clamp(gx, -units, units), clamp(gy, -units, units))
    }

    on(cartesianPlane, 'pointerdown', (e) => {
      const h = (e.target as Element).getAttribute?.('data-handle')
      if (h === 'A' || h === 'B') {
        dragging = h
        cartesianPlane.setPointerCapture(e.pointerId)
      }
    })
    on(cartesianPlane, 'pointermove', (e) => {
      if (!dragging) {
        return
      }
      const d = toData(e)
      // Always assign a fresh Vec (fresh-Vec invariant). Drag SAS touches
      // exactly one atom per event — see ADR-0001.
      if (dragging === 'A') {
        A.val = d
      }
      else {
        B.val = d
      }
    })
    on(cartesianPlane, 'pointerup', (e) => {
      dragging = null
      cartesianPlane.releasePointerCapture?.(e.pointerId)
    })
    on(cartesianPlane, 'pointercancel', () => {
      dragging = null
    })
  }
})
</script>
